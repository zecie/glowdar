{
  "schemaVersion": 1,
  "id": "glowmod",
  "version": "${version}",
  "name": "GlowMod",
  "description": "A client side mod designed to locate blocks in your render distance with configurable performance optimizations and a sleek GUI",
  "authors": [
    "chris"
  ],
  "contact": {},
  "license": "MIT",
  "icon": "assets/glowmod/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.glowmod.GlowModClient"
    ]
  },
  "mixins": [
    "glowmod.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.0",
    "fabric-api": "*",
    "minecraft": ">=1.21.11"
  }
}
